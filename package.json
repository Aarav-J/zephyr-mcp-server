{
  "name": "@personalhermes/zephyr-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Zephyr RTOS documentation - API signatures, Kconfig symbols, and Devicetree bindings",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zephyr-mcp": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "build-index": "node dist/scripts/build-index.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "better-sqlite3": "^11.7.0",
    "fast-xml-parser": "^5.0.0",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "typescript": "^5.7.0"
  }
}
